@model OrdersItem
<!DOCTYPE html>
<html>
<body>
    <form method="post" asp-controller="OrdersItems" asp-action="Edit">
        <select asp-for="OrderId" asp-items="ViewBag.Orders"></select><br />
        <select asp-for="ProductId" asp-items="ViewBag.Products"></select><br />
        <input asp-for="Quantity" placeholder="Quantity" value="@Model.Quantity" /><br />

        <button type="submit">Update order item</button>
    </form>
</body>
</html>