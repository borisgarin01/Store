@model Order
<!DOCTYPE html>
<html>
<body>
    <form method="post" asp-controller="Orders" asp-action="Edit">
        <select asp-for="ClientAddressId" asp-items="ViewBag.ClientsAddresses"></select><br />
        <input asp-for="OrderingDate" placeholder="Ordering Date" value="@Model.OrderingDate" /><br />

        <button type="submit">Update order</button>
    </form>
</body>
</html>